{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thunderbird.net/schemas/android/changelog-release.schema.json",
  "title": "Thunderbird for Android changelog release",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "version",
    "date",
    "notes"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "new",
              "changed",
              "fixed"
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "pullRequests": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "featureFlags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "source": {
            "type": "string",
            "enum": [
              "thunderbird-notes",
              "ckchangelog-xml"
            ]
          }
        }
      }
    }
  }
}
