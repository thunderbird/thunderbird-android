    <string name="funding_googleplay_contribution_tfa_recurring_xxl_title">Mimoriadny mesačný príspevok</string>
    <string name="funding_googleplay_contribution_tfa_recurring_xs_description">Vaša podpora nás ženie vpred! Každý príspevok prináša zmenu – ďakujeme!</string>
    <string name="funding_googleplay_contribution_tfa_recurring_s_description">Váš príspevok nám pomáha rásť a robiť zmysluplné kroky vpred – ďakujeme!</string>
    <string name="funding_googleplay_contribution_tfa_recurring_m_description">Váš príspevok je výnimočný! Ste kľúčom k napĺňaniu nášho poslania a dosahovaniu skutočných zmien.</string>
    <string name="funding_googleplay_contribution_tfa_recurring_l_description">Čo robíme, je možné najmä vďaka vám! Vaša štedrosť nám pomáha dosahovať nové míľniky.</string>
    <string name="funding_googleplay_contribution_tfa_recurring_xl_description">Vaša podpora nás inšpiruje! Váš príspevok nám pomáha posúvať hranice a dosahovať naše ciele.</string>
    <string name="funding_googleplay_contribution_tfa_recurring_xxl_description">Pomáhate nám snívať vo veľkom! Vaša podpora nám dáva silu dosahovať neobyčajné veci.</string>
